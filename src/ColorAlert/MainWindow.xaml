<Window x:Class="ColorAlert.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Color Alert"
        Width="680"
        Height="820"
        MinWidth="600"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}"
        Loaded="MainWindow_Loaded"
        StateChanged="MainWindow_StateChanged"
        Closing="MainWindow_Closing">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#FFE4E7EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="SmallButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,22">
                <TextBlock Text="Color Alert"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="28"
                           FontWeight="Bold" />
                <TextBlock Margin="0,5,0,0"
                           Text="當任一監看區域與匡選時的畫面不同時，播放提示音。"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="14" />
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="StatusIndicator"
                            Grid.Column="0"
                            Width="12"
                            Height="12"
                            Margin="0,2,12,0"
                            VerticalAlignment="Top"
                            CornerRadius="6"
                            Background="#FF98A2B3" />

                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="StatusText"
                                   Text="尚未開始"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="SampleText"
                                   Margin="0,4,0,0"
                                   Text="尚未加入監看區域"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="13" />
                    </StackPanel>

                    <Button x:Name="TestSoundButton"
                            Grid.Column="2"
                            Content="測試提示音"
                            Click="TestSoundButton_Click" />
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="監看區域" />
                        <TextBlock x:Name="RegionCountText"
                                   Margin="0,5,12,0"
                                   Text="0 / 10"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="13" />
                    </StackPanel>

                    <Button x:Name="AddRegionButton"
                            Grid.Row="0"
                            Grid.Column="1"
                            Content="新增區域"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="AddRegionButton_Click" />

                    <ScrollViewer Grid.Row="1"
                                  Grid.ColumnSpan="2"
                                  Margin="0,14,0,0"
                                  MaxHeight="260"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="RegionListPanel" />
                    </ScrollViewer>

                    <TextBlock Grid.Row="2"
                               Grid.ColumnSpan="2"
                               Margin="0,14,0,0"
                               Text="新增或重新選取時會保存當下畫面作為基準；基準只留在記憶體中。按 Esc 可取消。"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12" />

                    <CheckBox x:Name="ShowRegionOverlayCheckBox"
                              Grid.Row="3"
                              Grid.ColumnSpan="2"
                              Margin="0,14,0,0"
                              Content="顯示所有監看區域（橘色表示已觸發）"
                              IsChecked="True"
                              FontSize="14"
                              Checked="ShowRegionOverlayCheckBox_Changed"
                              Unchecked="ShowRegionOverlayCheckBox_Changed" />
                </Grid>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="偵測設定" />

                    <Grid Margin="0,18,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="敏感度"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="14" />
                        <TextBlock x:Name="SensitivityValueText"
                                   Grid.Row="0"
                                   Grid.Column="1"
                                   Text="標準"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="13" />
                        <Slider x:Name="SensitivitySlider"
                                Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Margin="0,7,0,0"
                                Minimum="1"
                                Maximum="100"
                                Value="50"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="SensitivitySlider_ValueChanged" />
                    </Grid>

                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Margin="0,0,18,0"
                                   VerticalAlignment="Center"
                                   Text="提示音次數"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="14" />

                        <RadioButton x:Name="OneSoundRadioButton"
                                     Grid.Column="1"
                                     Margin="0,0,18,0"
                                     VerticalAlignment="Center"
                                     GroupName="AlertCount"
                                     Content="一聲"
                                     IsChecked="True"
                                     Checked="AlertModeRadioButton_Checked" />
                        <RadioButton x:Name="ThreeSoundsRadioButton"
                                     Grid.Column="2"
                                     VerticalAlignment="Center"
                                     GroupName="AlertCount"
                                     Content="連響三聲"
                                     Checked="AlertModeRadioButton_Checked" />
                    </Grid>

                    <TextBlock Margin="0,14,0,0"
                               Text="敏感度越高，越小的畫面變化也會觸發。必須連續 3 次達標才會提示。"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button x:Name="StartButton"
                        Grid.Row="0"
                        Grid.Column="0"
                        Content="開始監看"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="StartButton_Click" />
                <Button x:Name="PauseButton"
                        Grid.Row="0"
                        Grid.Column="2"
                        Content="暫停"
                        IsEnabled="False"
                        Click="PauseButton_Click" />

                <TextBlock Grid.Row="1"
                           Grid.ColumnSpan="3"
                           Margin="0,15,0,0"
                           Text="最小化或關閉視窗後仍會留在系統匣；請從系統匣選單退出。"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="12" />
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
