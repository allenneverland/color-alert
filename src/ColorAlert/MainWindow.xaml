<Window x:Class="ColorAlert.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Color Alert"
        Width="600"
        Height="690"
        MinWidth="540"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}"
        Loaded="MainWindow_Loaded"
        StateChanged="MainWindow_StateChanged"
        Closing="MainWindow_Closing">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#FFE4E7EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,22">
                <TextBlock Text="Color Alert"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="28"
                           FontWeight="Bold" />
                <TextBlock Margin="0,5,0,0"
                           Text="當指定區域由黑色變成非黑色時，播放一次提示音。"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="14" />
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="StatusIndicator"
                            Grid.Column="0"
                            Width="12"
                            Height="12"
                            Margin="0,2,12,0"
                            VerticalAlignment="Top"
                            CornerRadius="6"
                            Background="#FF98A2B3" />

                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="StatusText"
                                   Text="尚未開始"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="SampleText"
                                   Margin="0,4,0,0"
                                   Text="目前非黑比例：—"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="13" />
                    </StackPanel>

                    <Button x:Name="TestSoundButton"
                            Grid.Column="2"
                            Content="測試提示音"
                            Click="TestSoundButton_Click" />
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="監看區域" />
                        <TextBlock x:Name="RegionText"
                                   Margin="0,7,12,0"
                                   Text="尚未選取"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="14" />
                    </StackPanel>

                    <Button x:Name="SelectRegionButton"
                            Grid.Row="0"
                            Grid.Column="1"
                            Content="選取區域"
                            Click="SelectRegionButton_Click" />

                    <TextBlock Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Margin="0,14,0,0"
                               Text="可跨螢幕框選；按 Esc 可取消且不會覆蓋原本區域。"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12" />
                </Grid>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="偵測設定" />

                    <Grid Margin="0,18,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="黑色容差"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="14" />
                        <TextBlock x:Name="ToleranceValueText"
                                   Grid.Row="0"
                                   Grid.Column="1"
                                   Text="12 / 255"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="13" />
                        <Slider x:Name="ToleranceSlider"
                                Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Margin="0,7,0,0"
                                Minimum="0"
                                Maximum="64"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="DetectionSlider_ValueChanged" />
                    </Grid>

                    <Grid Margin="0,18,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="非黑像素觸發比例"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="14" />
                        <TextBlock x:Name="RatioValueText"
                                   Grid.Row="0"
                                   Grid.Column="1"
                                   Text="1.0%"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="13" />
                        <Slider x:Name="RatioSlider"
                                Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Margin="0,7,0,0"
                                Minimum="0.1"
                                Maximum="20"
                                TickFrequency="0.1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="DetectionSlider_ValueChanged" />
                    </Grid>

                    <TextBlock Margin="0,14,0,0"
                               Text="必須連續 3 次達標才會提示；恢復黑色後才會重新待命。"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button x:Name="StartButton"
                        Grid.Row="0"
                        Grid.Column="0"
                        Content="開始監看"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="StartButton_Click" />
                <Button x:Name="PauseButton"
                        Grid.Row="0"
                        Grid.Column="2"
                        Content="暫停"
                        IsEnabled="False"
                        Click="PauseButton_Click" />

                <TextBlock Grid.Row="1"
                           Grid.ColumnSpan="3"
                           Margin="0,15,0,0"
                           Text="最小化後程式會留在系統匣。關閉視窗則會結束程式。"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="12" />
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
