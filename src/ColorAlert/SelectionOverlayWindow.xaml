<Window x:Class="ColorAlert.SelectionOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="選取監看區域"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="#99000000"
        ShowInTaskbar="False"
        Topmost="True"
        Cursor="Cross"
        WindowStartupLocation="Manual"
        PreviewMouseLeftButtonDown="Overlay_MouseLeftButtonDown"
        PreviewMouseMove="Overlay_MouseMove"
        PreviewMouseLeftButtonUp="Overlay_MouseLeftButtonUp"
        PreviewKeyDown="Overlay_KeyDown">
    <Grid x:Name="OverlayRoot" Background="Transparent">
        <Canvas x:Name="SelectionCanvas" IsHitTestVisible="False">
            <Rectangle x:Name="SelectionRectangle"
                       Visibility="Collapsed"
                       Stroke="#FF60A5FA"
                       StrokeThickness="2"
                       Fill="#332563EB" />

            <Border x:Name="SizeBadge"
                    Visibility="Collapsed"
                    Padding="8,4"
                    CornerRadius="5"
                    Background="#E6172033">
                <TextBlock x:Name="SizeText"
                           Foreground="White"
                           FontSize="13"
                           FontWeight="SemiBold" />
            </Border>
        </Canvas>

        <Border HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,28,0,0"
                Padding="18,12"
                CornerRadius="8"
                Background="#E6172033"
                IsHitTestVisible="False">
            <StackPanel>
                <TextBlock Text="拖曳滑鼠框選監看區域"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="InstructionText"
                           Margin="0,4,0,0"
                           Text="放開後按 Enter 確認，按 Esc 取消"
                           Foreground="#FFD0D5DD"
                           FontSize="13"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>

