<Application x:Class="ColorAlert.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FFF4F6FA" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#FF2563EB" />
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#FF1D4ED8" />
        <SolidColorBrush x:Key="TextBrush" Color="#FF172033" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#FF667085" />
    </Application.Resources>
</Application>

