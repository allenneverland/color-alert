<Window x:Class="ColorAlert.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="從畫面取色"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="#01000000"
        ShowInTaskbar="False"
        ShowActivated="True"
        Topmost="True"
        Cursor="Cross"
        WindowStartupLocation="Manual"
        PreviewMouseLeftButtonDown="Overlay_MouseLeftButtonDown"
        PreviewKeyDown="Overlay_KeyDown">
    <Grid Background="#01000000">
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,28,0,0"
                Padding="18,12"
                CornerRadius="8"
                Background="#E6172033"
                IsHitTestVisible="False">
            <StackPanel>
                <TextBlock Text="點擊畫面上的目標顏色"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock Margin="0,4,0,0"
                           Text="按 Esc 取消"
                           Foreground="#FFD0D5DD"
                           FontSize="13"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>

